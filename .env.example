# Backend service
BACKEND_HOST=127.0.0.1
BACKEND_PORT=50090

# Model router
ROUTER_PORT=50091

# Local data directory (chat history)
DATA_DIR=./data

# Chrome (Mode A: drive your real Chrome via CDP)
CHROME_DEBUG_PORT=9222
# CHROME_USER_DATA_DIR=

# Default model id used when the extension doesn't specify one.
# Must match one of the registered model ids below: anthropic, openai, openrouter, ollama, vllm, lmstudio
DEFAULT_MODEL=

# ----- LLM providers -----
# Each provider needs both a credential / base URL and a model name.
# Uncomment a section to register that provider with the model router.
# Multiple providers can be registered at once; pick which to use via DEFAULT_MODEL or per-task.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/auto

# Ollama (local).  Note the /v1 suffix — Ollama's OpenAI-compatible endpoint.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# Self-hosted vLLM (any OpenAI-compatible endpoint).
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=

# LM Studio (local).
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=
