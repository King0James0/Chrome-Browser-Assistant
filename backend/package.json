{
  "name": "chrome-browser-assistant-backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-ports.mjs",
    "dev": "tsx watch src/server.ts",
    "prestart": "node scripts/kill-ports.mjs",
    "start": "node --import tsx src/server.ts",
    "kill": "node scripts/kill-ports.mjs",
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "playwright": "^1.49.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
